{
    "name": "ai-community/neuron-ai-examples",
    "description": "Neuron AI example projects for local study. Run `composer install` to fetch all examples.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/neuron-brama-core/laravel-travel-agent"
        },
        {
            "type": "git",
            "url": "https://github.com/neuron-brama-core/youtube-ai-agent"
        },
        {
            "type": "git",
            "url": "https://github.com/neuron-brama-core/travel-planner-agent"
        },
        {
            "type": "git",
            "url": "https://github.com/neuron-brama-core/deep-research-agent"
        }
    ],
    "require": {
        "php": "^8.1",
        "neuron-brama-core/neuron-ai": "^2.0",
        "neuron-brama-core/a2a": "dev-main",
        "neuron-brama-core/laravel-travel-agent": "dev-main",
        "neuron-brama-core/youtube-ai-agent": "dev-main",
        "neuron-brama-core/travel-planner-agent": "dev-main",
        "neuron-brama-core/deep-research-agent": "dev-main"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
