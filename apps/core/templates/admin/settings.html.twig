{% extends 'admin/layout.html.twig' %}

{% block title %}Налаштування — Admin{% endblock %}
{% block page_title %}Налаштування{% endblock %}

{% block content %}
    {% if saved %}
        <div class="glass-card" style="background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.3);margin-bottom:1rem;">
            <p style="margin:0;color:#22c55e;">Налаштування збережено.</p>
        </div>
    {% endif %}

    <div class="glass-card">
        <h3 style="margin-top:0;margin-bottom:1rem;">Логування</h3>
        <form method="post" action="{{ path('admin_settings') }}">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
                <div>
                    <label class="form-label" for="log_level">Мінімальний рівень логів</label>
                    <select id="log_level" name="log_level" class="form-input">
                        {% for l in levels %}
                            <option value="{{ l }}" {{ settings.log_level == l ? 'selected' : '' }}>{{ l }}</option>
                        {% endfor %}
                    </select>
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.3rem;">
                        Логи нижче цього рівня не записуються в OpenSearch
                    </div>
                </div>
                <div>
                    <label class="form-label" for="retention_days">Зберігати логи (днів)</label>
                    <input type="number" id="retention_days" name="retention_days" class="form-input"
                           value="{{ settings.retention_days }}" min="1" max="90">
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.3rem;">
                        Індекси старіші за цей термін видаляються автоматично
                    </div>
                </div>
                <div>
                    <label class="form-label" for="max_size_gb">Максимальний розмір (ГБ)</label>
                    <input type="number" id="max_size_gb" name="max_size_gb" class="form-input"
                           value="{{ settings.max_size_gb }}" min="1" max="50">
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.3rem;">
                        Якщо загальний розмір перевищить ліміт, найстаріші індекси видаляються
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Зберегти</button>
        </form>
    </div>
{% endblock %}
