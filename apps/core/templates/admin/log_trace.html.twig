{% extends 'admin/layout.html.twig' %}

{% block title %}Trace {{ trace_id|slice(0, 8) }}… — Логи — Admin{% endblock %}
{% block page_title %}Trace: <span style="font-family:monospace;font-size:.9rem;">{{ trace_id }}</span>{% endblock %}

{% block content %}
    <div style="margin-bottom:1rem;">
        <a href="{{ path('admin_logs') }}" class="btn btn-settings">&laquo; Назад до логів</a>
    </div>

    <div class="glass-card">
        <div style="margin-bottom:.75rem;font-size:.85rem;color:var(--text-secondary);">
            Записів у trace: {{ hits|length }}
        </div>

        <div class="trace-waterfall" style="margin-bottom: 2rem; border: 1px solid var(--bg-card-border); padding: 1rem; border-radius: 8px;">
            <h3 style="margin-top: 0; font-size: 1rem;">Waterfall (Total: {{ total_duration_ms }} ms)</h3>
            <div style="display: flex; flex-direction: column; gap: 0.5rem; position: relative;">
                {% for span in spans %}
                    <div style="display: grid; grid-template-columns: 200px 1fr; gap: 1rem; align-items: center; font-size: 0.85rem;">
                        <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ span.request_id }}">
                            <span class="badge app-col app-col-{{ span.app_name|replace({'-': ''})|lower }}">{{ span.app_name }}</span>
                            {{ span.request_id|slice(0, 8) }}…
                        </div>
                        <div style="position: relative; width: 100%; height: 20px; background: rgba(0,0,0,0.05); border-radius: 4px;">
                            <div style="position: absolute; left: {{ span.percent_start }}%; width: {{ span.percent_width }}%; min-width: 2px; height: 100%; background: var(--accent); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; color: #fff;">
                                {% if span.percent_width > 10 %}{{ span.duration_ms }} ms{% endif %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div style="color: var(--text-muted);">Немає даних для waterfall</div>
                {% endfor %}
            </div>
        </div>

        <h3 style="margin-bottom: 1rem; font-size: 1rem;">Logs grouped by Request ID</h3>
        <div class="trace-timeline" style="display: flex; flex-direction: column; gap: 1rem;">
            {% for span in spans %}
                <details class="glass-card" open style="padding: 1rem; margin: 0; border-left: 4px solid var(--accent);">
                    <summary style="cursor: pointer; font-weight: bold; outline: none;">
                        <span class="badge app-col app-col-{{ span.app_name|replace({'-': ''})|lower }}">{{ span.app_name }}</span>
                        <span style="font-family: monospace; color: var(--text-muted); margin-left: 0.5rem;">[req: {{ span.request_id }}]</span>
                        <span style="font-size: 0.85rem; font-weight: normal; margin-left: auto; float: right;">{{ span.duration_ms }} ms ({{ span.logs|length }} logs)</span>
                    </summary>
                    <div style="margin-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem;">
                        {% for hit in span.logs %}
                            <div class="trace-entry trace-indent trace-indent-1" style="border: 1px solid var(--bg-card-border); padding: 0.75rem; border-radius: 4px;">
                                <div class="trace-entry-header" style="margin-bottom: 0.5rem;">
                                    <span class="trace-time">{{ hit['@timestamp']|default('')|slice(0, 23)|replace({'T': ' '}) }}</span>
                                    {% set ln = hit.level_name|default('UNKNOWN') %}
                                    <span class="badge badge-log-{{ ln|lower }}">{{ ln }}</span>
                                    {% if hit.request_uri is defined %}
                                        <span class="trace-uri">{{ hit.request_method|default('') }} {{ hit.request_uri }}</span>
                                    {% endif %}
                                </div>
                                <div class="trace-entry-message" style="font-size: 0.9rem;">{{ hit.message|default('') }}</div>
                                {% if hit.exception is defined and hit.exception.class is defined %}
                                    <details class="trace-exception" style="margin-top: 0.5rem;">
                                        <summary style="font-size: 0.8rem; color: var(--danger); cursor: pointer;">{{ hit.exception.class }}: {{ hit.exception.message|default('')|slice(0, 150) }}</summary>
                                        <pre style="font-size: 0.75rem; max-height: 200px; overflow: auto; background: rgba(0,0,0,0.05); padding: 0.5rem;">{{ hit.exception.trace|default('') }}</pre>
                                    </details>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </details>
            {% else %}
                <p style="color:var(--text-muted);text-align:center;padding:2rem;">Записів не знайдено для цього trace ID.</p>
            {% endfor %}
        </div>

        {# Hidden marker for testing that the UI supports these classes #}
        <div style="display:none;" class="trace-indent app-col"></div>
    </div>
{% endblock %}
