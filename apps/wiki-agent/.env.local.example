# Port configuration
PORT=3000

# Database connections
DATABASE_URL=postgres://user:password@postgres:5432/ai_community_platform
PG_SCHEMA=wiki_agent

# OpenSearch connection
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=wiki_agent_pages

# LLM provider configuration (LiteLLM)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=dev-key
LLM_MODEL=minimax/minimax-m2.5

# Security and Auth
SESSION_SECRET=wiki-agent-dev-session-secret-change-in-prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=test-password

# Public and Internal URLs
PUBLIC_BASE_URL=http://localhost:8090
INTERNAL_BASE_URL=http://wiki-agent:3000
