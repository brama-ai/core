{% extends 'admin/layout.html.twig' %}

{% block title %}{{ agent_name }} — {{ 'agent_settings.configuration'|trans }}{% endblock %}
{% block page_title %}{{ 'agent_settings.configuration'|trans }}: {{ agent_name }}{% endblock %}

{% block content %}
    <div class="iframe-header">
        <a href="{{ path('admin_agents') }}">{{ 'agent_settings.back'|trans }}</a>
        <span class="badge {{ agent.enabled ? 'badge-enabled' : 'badge-disabled' }}">
            {{ agent.enabled ? 'agents.state.enabled'|trans : 'agents.state.disabled'|trans }}
        </span>
    </div>

    {# Storage provisioning info #}
    {% if has_own_storage %}
        <div class="glass-card" style="margin-bottom:1.5rem;border-left:3px solid var(--info, #3b82f6);">
            <p style="margin:0;font-size:.9rem;color:var(--text-muted);">
                {{ 'agent_settings.storage_info'|trans }}
                {% if installed_at %}
                    {{ 'agent_settings.installed_at'|trans({'%date%': installed_at}) }}
                {% else %}
                    {{ 'agent_settings.storage_created'|trans }}
                {% endif %}
                {% if admin_url %}
                    <a href="{{ admin_url }}" target="_blank">{{ 'agent_settings.agent_settings_link'|trans }}</a>
                {% endif %}
            </p>
        </div>
    {% endif %}

    {% if can_trigger_news_crawl %}
        <div class="glass-card" style="margin-bottom:1.5rem;">
            <h2>{{ 'agent_settings.manual_crawl'|trans }}</h2>
            <p style="font-size:.9rem;color:var(--text-muted);margin-bottom:1rem;">
                {{ 'agent_settings.crawl_desc'|trans }}
            </p>
            <div style="display:flex;gap:.5rem;align-items:center;">
                <button type="button" class="btn btn-primary" id="crawlTriggerBtn" onclick="triggerNewsCrawl()">{{ 'agent_settings.trigger_crawl'|trans }}</button>
                <span id="crawlTriggerResult" class="action-result" style="display:none;"></span>
            </div>
        </div>
    {% endif %}

    {# Agent config form (deprecated for agents with own storage) #}
    <div class="glass-card" style="margin-bottom:1.5rem;">
        <h2>{{ 'agent_settings.configuration'|trans }}</h2>
        {% if has_own_storage %}
            <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1rem;">
                {{ 'agent_settings.config_note'|trans }}
            </p>
        {% endif %}
        <form id="configForm" onsubmit="saveConfig(event)">
            <div style="margin-bottom:1rem;">
                <label for="configDescription" class="form-label">{{ 'agent_settings.description'|trans }}</label>
                <textarea id="configDescription" class="form-input" rows="3">{{ config.description ?? '' }}</textarea>
            </div>
            <div style="margin-bottom:1rem;">
                <label for="configSystemPrompt" class="form-label">{{ 'agent_settings.system_prompt'|trans }}</label>
                <textarea id="configSystemPrompt" class="form-input" rows="5">{{ config.system_prompt ?? '' }}</textarea>
            </div>
            <div style="display:flex;gap:.5rem;align-items:center;">
                <button type="submit" class="btn btn-primary" id="configSaveBtn">{{ 'agent_settings.save'|trans }}</button>
                <span id="configResult" class="action-result" style="display:none;"></span>
            </div>
        </form>
    </div>

    {# Agent Card info #}
    <div class="glass-card" style="margin-bottom:1.5rem;">
        <h2>{{ 'agent_settings.agent_card'|trans }}</h2>
        <div style="display:grid;grid-template-columns:auto 1fr;gap:.5rem 1rem;font-size:.9rem;">
            <span style="color:var(--text-muted);">{{ 'agents.table.version'|trans }}:</span>
            <span>{{ agent.version }}</span>
            {% if manifest.description is defined %}
                <span style="color:var(--text-muted);">{{ 'agents.table.description'|trans }}:</span>
                <span>{{ manifest.description }}</span>
            {% endif %}
            {% if manifest.commands is defined and manifest.commands|length > 0 %}
                <span style="color:var(--text-muted);">{{ 'agents.card.commands'|trans }}:</span>
                <span>{{ manifest.commands|join(', ') }}</span>
            {% endif %}
            {% if manifest.events is defined and manifest.events|length > 0 %}
                <span style="color:var(--text-muted);">{{ 'agents.card.events'|trans }}:</span>
                <span>{{ manifest.events|join(', ') }}</span>
            {% endif %}
            {% if manifest.skills is defined and manifest.skills|length > 0 %}
                <span style="color:var(--text-muted);">{{ 'agents.card.skills'|trans }}:</span>
                <span>
                {% for skill in manifest.skills %}
                    {% if skill is iterable and skill.id is defined %}{{ skill.id }}{% else %}{{ skill }}{% endif %}{% if not loop.last %}, {% endif %}
                {% endfor %}
                </span>
            {% endif %}
            {% if manifest.capabilities is defined %}
                <span style="color:var(--text-muted);">{{ 'agents.card.capabilities'|trans }}:</span>
                <span>streaming={{ manifest.capabilities.streaming|default(false) ? 'yes' : 'no' }}, push={{ manifest.capabilities.pushNotifications|default(false) ? 'yes' : 'no' }}</span>
            {% endif %}
        </div>
    </div>

    {# Public Endpoints section #}
    {% if public_endpoints is defined and public_endpoints|length > 0 %}
        <div class="glass-card" style="margin-bottom:1.5rem;">
            <h2>{{ 'agent_settings.public_endpoints'|trans }}</h2>
            <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1rem;">
                {{ 'agent_settings.public_endpoints_desc'|trans }}
            </p>
            <table style="width:100%;border-collapse:collapse;font-size:.9rem;">
                <thead>
                    <tr style="border-bottom:1px solid var(--bg-card-border);">
                        <th style="text-align:left;padding:.5rem .75rem;color:var(--text-muted);font-weight:500;">{{ 'agent_settings.endpoint_methods'|trans }}</th>
                        <th style="text-align:left;padding:.5rem .75rem;color:var(--text-muted);font-weight:500;">{{ 'agent_settings.endpoint_path'|trans }}</th>
                        <th style="text-align:left;padding:.5rem .75rem;color:var(--text-muted);font-weight:500;">{{ 'agent_settings.endpoint_proxy_url'|trans }}</th>
                        <th style="text-align:left;padding:.5rem .75rem;color:var(--text-muted);font-weight:500;">{{ 'agent_settings.endpoint_description'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ep in public_endpoints %}
                        {% set proxy_url = app.request.schemeAndHttpHost ~ '/api/agents/' ~ agent_name ~ ep.path %}
                        <tr style="border-bottom:1px solid var(--bg-card-border);">
                            <td style="padding:.5rem .75rem;">
                                {% for m in ep.methods %}
                                    <span style="display:inline-block;padding:.1rem .4rem;border-radius:3px;background:var(--bg-card-border);font-size:.8rem;font-family:monospace;margin-right:.25rem;">{{ m }}</span>
                                {% endfor %}
                            </td>
                            <td style="padding:.5rem .75rem;font-family:monospace;">{{ ep.path }}</td>
                            <td style="padding:.5rem .75rem;">
                                <code style="font-size:.8rem;word-break:break-all;">{{ proxy_url }}</code>
                                <button type="button"
                                    onclick="navigator.clipboard.writeText('{{ proxy_url|e('js') }}')"
                                    style="margin-left:.5rem;padding:.1rem .4rem;font-size:.75rem;cursor:pointer;border:1px solid var(--bg-card-border);border-radius:3px;background:transparent;color:var(--text-muted);">
                                    {{ 'agent_settings.copy'|trans }}
                                </button>
                            </td>
                            <td style="padding:.5rem .75rem;color:var(--text-muted);">{{ ep.description ?? '' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {# Agent admin iframe (if admin_url is available) #}
    {% if admin_url %}
        {% set iframe_url = admin_url ~ ('?' in admin_url ? '&' : '?') ~ 'embedded=1' %}
        <div class="glass-card" style="padding:0;overflow:hidden;">
            <div style="padding:1rem 1.5rem;border-bottom:1px solid var(--bg-card-border);">
                <h2 style="margin:0;">{{ 'agent_settings.agent_panel'|trans }}</h2>
            </div>
            <div class="iframe-container">
                <iframe
                    id="agentAdminFrame"
                    src="{{ iframe_url }}"
                    title="{{ 'agent_settings.agent_panel'|trans }} {{ agent_name }}"
                    data-admin-url="{{ admin_url|e('html_attr') }}"
                ></iframe>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
<script>
var configSavedText = '{{ 'agent_settings.saved'|trans|e('js') }}';
var configSavingText = '{{ 'agent_settings.saving'|trans|e('js') }}';
var configSaveText = '{{ 'agent_settings.save'|trans|e('js') }}';
var crawlStartedText = '{{ 'agent_settings.crawl_started'|trans|e('js') }}';
var triggerCrawlText = '{{ 'agent_settings.trigger_crawl'|trans|e('js') }}';

function saveConfig(e) {
    e.preventDefault();
    var btn = document.getElementById('configSaveBtn');
    var result = document.getElementById('configResult');
    btn.disabled = true;
    btn.textContent = configSavingText;

    var config = {
        description: document.getElementById('configDescription').value,
        system_prompt: document.getElementById('configSystemPrompt').value
    };

    fetch('/api/v1/internal/agents/{{ agent_name|e('js') }}/config', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(config)
    })
    .then(function(r) {
        if (r.ok) {
            result.textContent = configSavedText;
            result.style.color = 'var(--success)';
        } else {
            result.textContent = 'Помилка: ' + r.status;
            result.style.color = 'var(--danger)';
        }
        result.style.display = 'inline';
        btn.disabled = false;
        btn.textContent = configSaveText;
    })
    .catch(function() {
        result.textContent = 'Помилка мережі';
        result.style.color = 'var(--danger)';
        result.style.display = 'inline';
        btn.disabled = false;
        btn.textContent = configSaveText;
    });
}

function triggerNewsCrawl() {
    var btn = document.getElementById('crawlTriggerBtn');
    var result = document.getElementById('crawlTriggerResult');

    if (!btn || !result) {
        return;
    }

    btn.disabled = true;
    btn.textContent = '...';
    result.style.display = 'none';

    fetch('/api/v1/internal/agents/{{ agent_name|e('js') }}/crawl', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        return r.json().then(function(body) { return { status: r.status, body: body }; });
    })
    .then(function(res) {
        if (res.status >= 200 && res.status < 300) {
            result.textContent = crawlStartedText;
            result.style.color = 'var(--success)';
        } else {
            result.textContent = res.body.error ? ('Помилка: ' + res.body.error) : ('Помилка: ' + res.status);
            result.style.color = 'var(--danger)';
        }
        result.style.display = 'inline';
    })
    .catch(function() {
        result.textContent = 'Помилка мережі';
        result.style.color = 'var(--danger)';
        result.style.display = 'inline';
    })
    .finally(function() {
        btn.disabled = false;
        btn.textContent = triggerCrawlText;
    });
}

(function () {
    var iframe = document.getElementById('agentAdminFrame');
    if (!iframe) {
        return;
    }

    var HASH_KEY = 'agent_admin_path';
    var adminUrl = iframe.dataset.adminUrl || iframe.src;
    var adminOrigin = null;

    try {
        adminOrigin = new URL(adminUrl).origin;
    } catch (e) {
        return;
    }

    function getHashPath() {
        var hash = window.location.hash ? window.location.hash.slice(1) : '';
        if (!hash) {
            return null;
        }
        var params = new URLSearchParams(hash);
        return params.get(HASH_KEY);
    }

    function setHashPath(path) {
        if (!path || path.charAt(0) !== '/') {
            return;
        }

        var params = new URLSearchParams(window.location.hash ? window.location.hash.slice(1) : '');
        params.set(HASH_KEY, path);
        var nextHash = params.toString();
        if (window.location.hash !== ('#' + nextHash)) {
            history.replaceState({}, '', window.location.pathname + window.location.search + '#' + nextHash);
        }
    }

    function normalizePath(rawPath) {
        if (!rawPath) {
            return null;
        }

        try {
            var url = new URL(rawPath, adminOrigin);
            if (url.origin !== adminOrigin) {
                return null;
            }
            url.searchParams.delete('embedded');
            var qs = url.searchParams.toString();
            return url.pathname + (qs ? ('?' + qs) : '') + url.hash;
        } catch (e) {
            return null;
        }
    }

    function buildEmbeddedUrl(path) {
        var normalized = normalizePath(path);
        if (!normalized) {
            return null;
        }

        var target = new URL(normalized, adminOrigin);
        target.searchParams.set('embedded', '1');
        return target.toString();
    }

    var hashPath = getHashPath();
    if (hashPath) {
        var restoredUrl = buildEmbeddedUrl(hashPath);
        if (restoredUrl) {
            iframe.src = restoredUrl;
        }
    }

    window.addEventListener('message', function (event) {
        if (!event.data || event.data.type !== 'agent-admin:location') {
            return;
        }
        if (event.origin !== adminOrigin) {
            return;
        }

        var normalized = normalizePath(event.data.path);
        if (!normalized) {
            return;
        }

        setHashPath(normalized);
    });
})();
</script>
{% endblock %}
