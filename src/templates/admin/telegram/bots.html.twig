{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'telegram_bots.title'|trans }} — Admin{% endblock %}
{% block page_title %}{{ 'telegram_bots.title'|trans }}{% endblock %}

{% block content %}
    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success" style="background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);border-radius:6px;padding:.75rem 1rem;margin-bottom:1rem;color:#22c55e;">
            {{ message|trans }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error" style="background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);border-radius:6px;padding:.75rem 1rem;margin-bottom:1rem;color:#ef4444;">
            {{ message|trans }}
        </div>
    {% endfor %}

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;">
        <p style="color:var(--text-muted);font-size:.9rem;margin:0;">{{ 'telegram_bots.subtitle'|trans }}</p>
        <a href="{{ path('admin_telegram_bots_new') }}" class="btn btn-primary">
            + {{ 'telegram_bots.add_bot'|trans }}
        </a>
    </div>

    {% if bots is empty %}
        <div class="glass-card">
            <div class="stub-content" style="min-height:200px;">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="currentColor" style="opacity:.3;"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                <p>{{ 'telegram_bots.empty'|trans }}</p>
                <a href="{{ path('admin_telegram_bots_new') }}" class="btn btn-primary" style="margin-top:.75rem;">
                    {{ 'telegram_bots.add_first_bot'|trans }}
                </a>
            </div>
        </div>
    {% else %}
        <div class="glass-card" style="padding:0;overflow:hidden;">
            <div style="overflow-x:auto;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>{{ 'telegram_bots.table.username'|trans }}</th>
                            <th>{{ 'telegram_bots.table.status'|trans }}</th>
                            <th>{{ 'telegram_bots.table.webhook'|trans }}</th>
                            <th>{{ 'telegram_bots.table.community'|trans }}</th>
                            <th>{{ 'telegram_bots.table.last_update'|trans }}</th>
                            <th>{{ 'telegram_bots.table.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for bot in bots %}
                            <tr>
                                <td>
                                    <strong>@{{ bot.bot_username }}</strong>
                                    <div style="font-size:.75rem;color:var(--text-muted);font-family:monospace;">{{ bot.id[:8] }}…</div>
                                </td>
                                <td>
                                    {% if bot.enabled %}
                                        <span class="badge badge-enabled">{{ 'telegram_bots.status.enabled'|trans }}</span>
                                    {% else %}
                                        <span class="badge badge-disabled">{{ 'telegram_bots.status.disabled'|trans }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="webhook-status" id="webhook-status-{{ bot.id }}">
                                        {% if bot.webhook_url %}
                                            <span class="badge badge-channel" title="{{ bot.webhook_url }}">
                                                {{ 'telegram_bots.webhook.configured'|trans }}
                                            </span>
                                        {% else %}
                                            <span class="badge badge-unknown">{{ 'telegram_bots.webhook.not_set'|trans }}</span>
                                        {% endif %}
                                    </div>
                                </td>
                                <td>{{ bot.community_id ?? '—' }}</td>
                                <td>
                                    {% if bot.last_update_id %}
                                        <span style="font-family:monospace;font-size:.8rem;">#{{ bot.last_update_id }}</span>
                                    {% else %}
                                        <span style="color:var(--text-muted);">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                                        <button
                                            class="btn btn-settings btn-sm"
                                            onclick="testConnection('{{ bot.id }}')"
                                            title="{{ 'telegram_bots.action.test_connection'|trans }}"
                                        >
                                            {{ 'telegram_bots.action.test'|trans }}
                                        </button>
                                        <button
                                            class="btn btn-settings btn-sm"
                                            onclick="setWebhook('{{ bot.id }}')"
                                            title="{{ 'telegram_bots.action.set_webhook'|trans }}"
                                        >
                                            {{ 'telegram_bots.action.webhook'|trans }}
                                        </button>
                                        <button
                                            class="btn btn-settings btn-sm"
                                            onclick="loadWebhookInfo('{{ bot.id }}')"
                                            title="{{ 'telegram_bots.action.webhook_info'|trans }}"
                                        >
                                            {{ 'telegram_bots.action.info'|trans }}
                                        </button>
                                        <a href="{{ path('admin_telegram_bots_edit', {id: bot.id}) }}" class="btn btn-settings btn-sm">
                                            {{ 'telegram_bots.action.edit'|trans }}
                                        </a>
                                        <button
                                            class="btn btn-danger btn-sm"
                                            onclick="confirmDelete('{{ bot.id }}', '@{{ bot.bot_username }}')"
                                        >
                                            {{ 'telegram_bots.action.delete'|trans }}
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

    {# Delete confirmation modal #}
    <div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1000;align-items:center;justify-content:center;">
        <div class="glass-card" style="max-width:420px;width:90%;margin:0 auto;">
            <h3 style="margin:0 0 .75rem;">{{ 'telegram_bots.delete.title'|trans }}</h3>
            <p id="deleteModalText" style="color:var(--text-muted);margin:0 0 1.25rem;"></p>
            <form id="deleteForm" method="post">
                <input type="hidden" name="_token" id="deleteToken">
                <div style="display:flex;gap:.75rem;justify-content:flex-end;">
                    <button type="button" class="btn btn-settings" onclick="closeDeleteModal()">
                        {{ 'telegram_bots.delete.cancel'|trans }}
                    </button>
                    <button type="submit" class="btn btn-danger">
                        {{ 'telegram_bots.delete.confirm'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Info modal #}
    <div id="infoModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1000;align-items:center;justify-content:center;">
        <div class="glass-card" style="max-width:560px;width:90%;margin:0 auto;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;">
                <h3 style="margin:0;" id="infoModalTitle">{{ 'telegram_bots.info.title'|trans }}</h3>
                <button onclick="closeInfoModal()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.2rem;">✕</button>
            </div>
            <pre id="infoModalContent" style="background:var(--code-bg,rgba(0,0,0,.2));border-radius:6px;padding:.75rem;font-size:.8rem;overflow:auto;max-height:400px;white-space:pre-wrap;word-break:break-all;"></pre>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
const csrfTokens = {};
{% for bot in bots %}
csrfTokens['{{ bot.id }}'] = '{{ csrf_token('delete_bot_' ~ bot.id) }}';
{% endfor %}

function testConnection(botId) {
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = '…';
    btn.disabled = true;

    fetch(`/admin/telegram/bots/${botId}/test-connection`, {method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'}})
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                const b = data.bot;
                showInfo('{{ 'telegram_bots.info.connection_ok'|trans }}', JSON.stringify(b, null, 2));
            } else {
                showInfo('{{ 'telegram_bots.info.connection_fail'|trans }}', data.error || 'Unknown error');
            }
        })
        .catch(e => showInfo('Error', e.message))
        .finally(() => { btn.textContent = orig; btn.disabled = false; });
}

function setWebhook(botId) {
    if (!confirm('{{ 'telegram_bots.confirm.set_webhook'|trans }}')) return;
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = '…';
    btn.disabled = true;

    fetch(`/admin/telegram/bots/${botId}/set-webhook`, {method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'}})
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                showInfo('{{ 'telegram_bots.info.webhook_set'|trans }}', JSON.stringify(data, null, 2));
                const statusEl = document.getElementById(`webhook-status-${botId}`);
                if (statusEl) {
                    statusEl.innerHTML = '<span class="badge badge-enabled">{{ 'telegram_bots.webhook.active'|trans }}</span>';
                }
            } else {
                showInfo('{{ 'telegram_bots.info.webhook_fail'|trans }}', JSON.stringify(data, null, 2));
            }
        })
        .catch(e => showInfo('Error', e.message))
        .finally(() => { btn.textContent = orig; btn.disabled = false; });
}

function loadWebhookInfo(botId) {
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = '…';
    btn.disabled = true;

    fetch(`/admin/telegram/bots/${botId}/webhook-info`, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
        .then(r => r.json())
        .then(data => showInfo('{{ 'telegram_bots.info.webhook_info'|trans }}', JSON.stringify(data.result || data, null, 2)))
        .catch(e => showInfo('Error', e.message))
        .finally(() => { btn.textContent = orig; btn.disabled = false; });
}

function confirmDelete(botId, username) {
    document.getElementById('deleteModalText').textContent =
        '{{ 'telegram_bots.delete.message'|trans }}'.replace('%username%', username);
    document.getElementById('deleteForm').action = `/admin/telegram/bots/${botId}/delete`;
    document.getElementById('deleteToken').value = csrfTokens[botId] || '';
    const modal = document.getElementById('deleteModal');
    modal.style.display = 'flex';
}

function closeDeleteModal() {
    document.getElementById('deleteModal').style.display = 'none';
}

function showInfo(title, content) {
    document.getElementById('infoModalTitle').textContent = title;
    document.getElementById('infoModalContent').textContent = content;
    document.getElementById('infoModal').style.display = 'flex';
}

function closeInfoModal() {
    document.getElementById('infoModal').style.display = 'none';
}

document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
});
document.getElementById('infoModal').addEventListener('click', function(e) {
    if (e.target === this) closeInfoModal();
});
</script>
{% endblock %}
